# Copy this file to `.env` and fill in your real key.
# `.env` is gitignored and will NEVER be committed. This `.env.example` is safe
# to commit because it contains no real secret.
#
#   cp .env.example .env      # then edit .env and paste your key
#
GEMINI_API_KEY=

# Your GitHub username — used to build the local baseURL
#   https://<GITHUB_USERNAME>.github.io/MAXIMAULISM/
# (The GitHub Actions deploy derives baseURL automatically, so this is only
#  needed for local `hugo server` convenience.)
GITHUB_USERNAME=
